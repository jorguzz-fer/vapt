# ── Database ──────────────────────────────────────────────────────────────────
# Coolify: use the internal Postgres URL from the database service
DATABASE_URL=postgresql://vapt:vapt@localhost:5432/vapt

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# ── API service ───────────────────────────────────────────────────────────────
# Port the NestJS API listens on (default 3333)
PORT=3333
NODE_ENV=production

# ── Web service ───────────────────────────────────────────────────────────────
# Internal URL (server-side fetch) — use private network name in Coolify
API_URL=http://api:3333

# Public URL (browser fetch) — must be the public-facing API domain
NEXT_PUBLIC_API_URL=https://api.vapt.com.br

# ── Payments (Fase 1) ─────────────────────────────────────────────────────────
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_SECRET=
